@model Compras.com.Models.Usuario

<h2>👁️ Detalhes do Usuário</h2>

<a asp-controller="Admin" asp-action="Index">Voltar</a>
<a asp-controller="Login" asp-action="Logout" style="float:right;">❌</a>

<hr />

@if (Model != null)
{
    <p><b>Nome:</b> @Model.Nome</p>
    <p><b>Tipo:</b> @Model.Tipo</p>
    <p><b>Email:</b> @Model.Email</p>
    <p><b>Documento:</b> @Model.Documento</p>
    <p><b>Endereço:</b> @Model.Endereco</p>
    <p><b>Telefone:</b> @Model.Telefone</p>
    <p><b>Contato:</b> @Model.Contato</p>
    <p><b>Status:</b> @(Model.Ativo ? "Ativo" : "Bloqueado")</p>
}
else
{
    <p>Usuário não encontrado.</p>
}
@model IEnumerable<Compras.com.Models.Usuario>
@{ Layout = "_Layout"; }

<div class="container mt-4 text-white">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Gestão de Usuários</h2>
        <div>
            <a href="/Admin/Criar?tipo=Fornecedor" class="btn btn-primary btn-sm"> + Novo Fornecedor</a>
            <a href="/Admin/Criar?tipo=Comprador" class="btn btn-info btn-sm"> + Novo Comprador</a>
        </div>
    </div>
    
    <table class="table table-dark table-hover mt-3">
        <thead>
            <tr>
                <th>Nome</th>
                <th>Login</th>
                <th>Tipo</th>
                <th>Status</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var u in Model){
            <tr>
                <td>@u.Nome</td>
                <td>@u.Login</td>
                <td>@u.Tipo</td>
                <td>@(u.Ativo ? "Ativo" : "Bloqueado")</td>
                <td>
                    <a asp-action="AlternarStatus" asp-route-id="@u.Id" class="btn btn-sm @(u.Ativo?"btn-warning":"btn-success")">
                        @(u.Ativo ? "Bloquear" : "Ativar")
                    </a>
                    <a asp-action="Excluir" asp-route-id="@u.Id" class="btn btn-sm btn-danger" onclick="return confirm('Excluir?')">Excluir</a>
                </td>
            </tr>}
        </tbody>
    </table>
</div>
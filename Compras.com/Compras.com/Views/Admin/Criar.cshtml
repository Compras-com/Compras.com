@model Compras.com.Models.Usuario

<h2>➕ Cadastrar Usuário</h2>

@* Ajustado para voltar ao Painel sem deslogar *@
<a asp-controller="Admin" asp-action="Index">Voltar</a>
<a asp-controller="Login" asp-action="Index" style="float:right;">❌</a>

<hr />

<form asp-action="Criar" method="post">

    @* Campo de Nome *@
    <input asp-for="Nome" placeholder="Nome Completo / Razão Social" class="form-control mb-2" />
    <span asp-validation-for="Nome" class="text-danger"></span>
    <br />

    @* Seleção de Tipo *@
    <label>Tipo de Usuário:</label><br />
    <select asp-for="Tipo" class="form-control mb-2">
        <option value="Fornecedor">Fornecedor</option>
        <option value="Comprador">Comprador</option>
    </select>
    <br />

    @* CAMPOS DE ACESSO (LOGIN E SENHA) *@
    <fieldset style="border: 1px solid #ccc; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
        <legend style="font-size: 1.1em; width: auto; padding: 0 10px;">🔑 Dados de Acesso</legend>
        
        <label>E-mail (Será o Login):</label><br />
        <input asp-for="Email" type="email" placeholder="exemplo@email.com" class="form-control mb-2" />
        <span asp-validation-for="Email" class="text-danger"></span>
        <br />

        <label>Senha de Acesso:</label><br />
        <input asp-for="Senha" type="password" placeholder="Digite uma senha segura" class="form-control mb-2" />
        <span asp-validation-for="Senha" class="text-danger"></span>
    </fieldset>

    @* Dados Documentais *@
    <input asp-for="Documento" placeholder="CNPJ/CPF" class="form-control mb-2" />
    <br />

    <input asp-for="Endereco" placeholder="Endereço Completo" class="form-control mb-2" />
    <br />

    <input asp-for="Telefone" placeholder="Telefone de Contato" class="form-control mb-2" />
    <br />

    <input asp-for="Contato" placeholder="Nome do Contato Responsável" class="form-control mb-2" />
    <br /><br />

    <button type="submit" class="btn btn-primary" style="padding: 10px 30px;">Salvar Cadastro</button>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
@{
    ViewData["Title"] = "Login";
}

<div style="width:300px;margin:100px auto;text-align:center;border:1px solid #ccc;padding:20px;">

    <h2>Compras.com</h2>

    <form asp-controller="Login" asp-action="Entrar" method="post">

        <input type="text" name="email" placeholder="Usuário" required />
        <br /><br />

        <input type="password" name="senha" placeholder="Senha" required />
        <br /><br />

        <button type="submit">Entrar</button>

    </form>

    @if (ViewBag.Erro != null)
    {
        <p style="color:red">@ViewBag.Erro</p>
    }

</div>
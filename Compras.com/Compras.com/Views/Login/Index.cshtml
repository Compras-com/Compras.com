@model Compras.com.Models.Usuario
@{
    // Mantém a barra superior original (Compras.com, Home, Privacy, Sair)
    Layout = "_Layout"; 
}

<style>
    /* Estilo para cobrir a tela toda com a imagem de fundo */
    body {
        background: url('/images/fundo-login.jpg') no-repeat center center fixed;
        background-size: cover;
        margin: 0;
        padding: 0;
    }

    /* Container principal para centralizar o card sem sumir com a navbar */
    .main-login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 85vh; /* Ajustado para dar espaço à barra superior */
    }

    /* O Card de Login baseado na foto que você enviou */
    .login-card {
        background: rgba(30, 30, 30, 0.85); /* Escuro com transparência */
        padding: 45px;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.6);
        width: 100%;
        max-width: 420px;
        text-align: center;
        color: #ffffff;
        backdrop-filter: blur(10px); /* Efeito de vidro */
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .login-card h2 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 5px;
    }

    .login-card p {
        color: #cccccc;
        margin-bottom: 30px;
        font-size: 0.9rem;
    }

    /* Campos de entrada personalizados */
    .custom-input {
        background: rgba(255, 255, 255, 0.08) !important;
        border: 1px solid rgba(255, 255, 255, 0.2) !important;
        color: white !important;
        padding: 12px 15px;
        border-radius: 8px;
        margin-bottom: 20px;
        width: 100%;
    }

    .custom-input::placeholder {
        color: #aaaaaa;
    }

    /* Botão de Entrar */
    .btn-login {
        background-color: #4facfe;
        background-image: linear-gradient(135deg, #00f2fe 0%, #4facfe 100%);
        border: none;
        color: white;
        padding: 12px;
        border-radius: 8px;
        width: 100%;
        font-weight: bold;
        font-size: 1rem;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .btn-login:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(79, 172, 254, 0.4);
    }

    .error-msg {
        background: rgba(255, 82, 82, 0.2);
        color: #ff5252;
        padding: 10px;
        border-radius: 5px;
        margin-top: 15px;
        font-size: 0.85rem;
    }
</style>

<div class="main-login-container">
    <div class="login-card">
        <h2>Bem-vindo</h2>
        <p>Acesse sua conta para continuar</p>

        <form asp-controller="Login" asp-action="Entrar" method="post">
            <div class="text-start">
                <label style="font-size: 0.8rem; margin-left: 5px;">Usuário</label>
                <input type="text" name="login" class="form-control custom-input" placeholder="Seu nome de usuário" required />
            </div>

            <div class="text-start">
                <label style="font-size: 0.8rem; margin-left: 5px;">Senha</label>
                <input type="password" name="senha" class="form-control custom-input" placeholder="Sua senha" required />
            </div>

            <button type="submit" class="btn-login">Entrar</button>
        </form>

        @if (TempData["Erro"] != null)
        {
            <div class="error-msg">
                <i class="fas fa-exclamation-circle"></i> @TempData["Erro"]
            </div>
        }
    </div>
</div>
@model IEnumerable<Compras.com.Models.Produto>
@using Microsoft.AspNetCore.Http

@{
    // Pegamos os dados da sessão para saber quem está logado
    var tipo = Context.Session.GetString("tipo");
    var emailLogado = Context.Session.GetString("email");
}

<div class="container mt-4">

    @* --- BLOCO PARA O FORNECEDOR (CADASTRO) --- *@
    @if (tipo == "Fornecedor")
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">🏭 Painel do Fornecedor - Cadastrar Produto</h4>
            </div>
            <div class="card-body">
                <form asp-controller="Produtos" asp-action="Create" method="post">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label small fw-bold">Nome do Produto</label>
                            <input name="Nome" class="form-control" placeholder="Ex: Telha Brasilit" required />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small fw-bold">Preço (R$)</label>
                            <input name="Preco" type="number" step="0.01" class="form-control" placeholder="0,00" required />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small fw-bold">Imposto (%)</label>
                            <input name="Imposto" type="number" step="0.01" class="form-control" placeholder="0" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small fw-bold">Inclui Imposto?</label>
                            <select name="ComImposto" class="form-select">
                                <option value="true">Sim</option>
                                <option value="false">Não</option>
                            </select>
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="submit" class="btn btn-success w-100">✅ Salvar</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
        <h4 class="mb-3">📋 Meus Produtos Listados</h4>
    }

    @* --- BLOCO PARA O COMPRADOR (BUSCA) --- *@
    @if (tipo == "Comprador")
    {
        <div class="text-center mb-5">
            <h2 class="display-6">🛒 Área de Compras</h2>
            <p class="text-muted">Busque produtos e compare os melhores preços entre fornecedores.</p>
            
            <form asp-controller="Produtos" asp-action="Buscar" method="get" class="mx-auto" style="max-width: 600px;">
                <div class="input-group input-group-lg shadow-sm">
                    <input name="termo" class="form-control" placeholder="O que você deseja comprar?" />
                    <button type="submit" class="btn btn-info text-white">🔍 Buscar</button>
                </div>
            </form>
            
            <div class="mt-3">
                <a asp-action="Equalizacao" class="btn btn-outline-primary shadow-sm">
                    📊 Ver Tabela de Equalização de Preços
                </a>
            </div>
        </div>
        <h4 class="mb-3">🔎 Resultados encontrados:</h4>
    }

    @* --- TABELA GERAL DE PRODUTOS --- *@
    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover border shadow-sm">
                <thead class="table-dark">
                    <tr>
                        <th>📦 Produto</th>
                        <th>💰 Preço</th>
                        <th>🏭 Fornecedor</th>
                        <th class="text-center">⚡ Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="align-middle fw-bold">@item.Nome</td>
                            <td class="align-middle text-success fw-bold">@item.Preco.ToString("C")</td>
                            <td class="align-middle text-muted small">@item.EmailFornecedor</td>
                            <td class="text-center align-middle">
                                
                                @if (tipo == "Comprador")
                                {
                                    @* Ação para Comprador *@
                                    <a href="mailto:@emailLogado?subject=Pedido - @item.Nome&body=Produto: @item.Nome - Preço: @item.Preco.ToString("C") - Fornecedor: @item.EmailFornecedor" 
                                       class="btn btn-sm btn-success px-3">
                                        📩 Selecionar
                                    </a>
                                }
                                else if (tipo == "Fornecedor" && item.EmailFornecedor == emailLogado)
                                {
                                    @* Ações para o Fornecedor dono do produto *@
                                    <div class="btn-group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                            ✏️ Editar
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" 
                                           class="btn btn-sm btn-danger" 
                                           onclick="return confirm('Deseja realmente excluir este produto?')">
                                            🗑️ Excluir
                                        </a>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-light text-center border shadow-sm">
            <p class="mb-0 text-muted italic">Nenhum produto para exibir no momento.</p>
        </div>
    }

</div>
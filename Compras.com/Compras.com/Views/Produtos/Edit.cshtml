@model Compras.com.Models.Produto

<div class="container mt-4">
    <h2>✏️ Editar Produto</h2>
    <hr />
    <form asp-action="Atualizar" method="post" class="card p-4 shadow-sm">
        <input type="hidden" asp-for="Id" />
        
        <div class="mb-3">
            <label class="form-label">Nome do Produto</label>
            <input asp-for="Nome" class="form-control" required />
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Preço</label>
                <input asp-for="Preco" type="number" step="0.01" class="form-control" required />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Imposto</label>
                <input asp-for="Imposto" type="number" step="0.01" class="form-control" />
            </div>
        </div>

        <div class="mb-3 form-check">
            <input asp-for="ComImposto" type="checkbox" class="form-check-input" id="checkImp">
            <label class="form-check-label" for="checkImp">Preço já inclui impostos?</label>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">💾 Salvar Alterações</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>
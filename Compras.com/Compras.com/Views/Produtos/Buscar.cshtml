@model List<Compras.com.Models.Produto>

<h2>Resultado da Busca</h2>

<form asp-controller="Produtos" asp-action="Buscar" method="get">
    <input type="text" name="termo" placeholder="Buscar produto" />
    <button type="submit">Buscar</button>
</form>

<br />

@if (Model != null && Model.Count > 0)
{
    <table border="1" width="100%">
        <tr>
            <th>Produto</th>
            <th>Preço</th>
            <th>Fornecedor</th>
        </tr>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nome</td>
                <td>@item.Preco</td>
                <td>@item.EmailFornecedor</td>
            </tr>
        }
    </table>
}
else
{
    <p>Nenhum produto encontrado.</p>
}

<br />

<a asp-controller="Home" asp-action="Comprador">⬅ Voltar</a>
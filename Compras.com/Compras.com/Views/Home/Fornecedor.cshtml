@model List<Compras.com.Models.Produto>

<h2>🏪 Área do Fornecedor</h2>

<a asp-controller="Login" asp-action="Logout">Voltar</a> |
<a asp-controller="Conta" asp-action="AlterarSenha">Alterar Senha</a>
<a asp-controller="Login" asp-action="Logout" style="float:right;">❌</a>

<hr />

<h3>📦 Cadastrar Produto</h3>

<form asp-controller="Fornecedor" asp-action="Salvar" method="post">

    <input name="Nome" placeholder="Produto" required /><br /><br />

    <input name="Preco" placeholder="Preço" required /><br /><br />

    <input name="Imposto" placeholder="Imposto (ex: 3,5)" required /><br /><br />

    <input name="Desconto" placeholder="Desconto (ex: 2,5)" required /><br /><br />

    <button type="submit">Salvar</button>
</form>

<hr />

<h3>📋 Meus Produtos</h3>

@if (Model != null && Model.Count > 0)
{
    <table border="1" width="100%">
        <tr>
            <th>Produto</th>
            <th>Preço</th>
            <th>Imposto</th>
            <th>Desconto</th>
        </tr>

        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Nome</td>
                <td>@p.Preco</td>
                <td>@p.Imposto</td>
                <td>@p.Desconto</td>
            </tr>
        }
    </table>
}
else
{
    <p>Nenhum produto cadastrado.</p>
}
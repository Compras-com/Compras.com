@model IEnumerable<Compras.com.Models.Produto>
@{ Layout = "_Layout"; }

<div class="container mt-4 text-white">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Planilha de Equalização</h2>
        <span class="badge bg-info">Perfil: Comprador</span>
    </div>
    <hr />

    <table class="table table-dark table-striped table-hover mt-3">
        <thead>
            <tr>
                <th>Fornecedor</th>
                <th>Produto</th>
                <th>Preço Base</th>
                <th>IPI (%)</th>
                <th>Frete</th>
                <th>Total Final</th>
                <th>Ação</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var p in Model) {
                // Cálculo da equalização: Preço + IPI + Frete - Desconto
                var total = p.Preco + (p.Preco * (p.Ipi / 100)) + p.Frete - p.Desconto;
                <tr>
                    <td>@p.Fornecedor?.Nome</td>
                    <td>@p.Nome</td>
                    <td>@p.Preco.ToString("C")</td>
                    <td>@p.Ipi%</td>
                    <td>@p.Frete.ToString("C")</td>
                    <td class="text-warning fw-bold">@total.ToString("C")</td>
                    <td>
                        <button class="btn btn-sm btn-success">Comprar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
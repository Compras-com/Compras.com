@model List<Compras.com.Models.Produto>

<h2>Produtos</h2>

<a href="/Produtos/Create">Novo Produto</a>

<table border="1">

<tr>
<th>Nome</th>
<th>Preço</th>
<th>Imposto</th>
<th>Fornecedor</th>
</tr>

@foreach (var p in Model)
{
<tr>
<td>@p.Nome</td>
<td>@p.PrecoUnitario</td>
<td>@(p.ComImposto ? "Com imposto" : "Sem imposto")</td>
<td>@p.EmailFornecedor</td>
</tr>
}

</table>
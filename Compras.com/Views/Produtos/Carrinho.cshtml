@model List<Compras.com.Models.CotacaoItem>

<h2>Minha Cotação</h2>

@if(Model.Count == 0)
{
<p>Nenhum item.</p>
}
else
{

<table border="1">

<tr>
<th>Produto</th>
<th>Preço</th>
<th>Fornecedor</th>
</tr>

@foreach (var item in Model)
{
<tr>
<td>@item.NomeProduto</td>
<td>@item.MelhorPreco</td>
<td>@item.MelhorFornecedor</td>
</tr>
}

</table>

<br>

<a href="/Produtos/EnviarEmail">Enviar por Email</a>

}
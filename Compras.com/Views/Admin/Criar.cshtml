<h2>➕ Cadastrar Usuário</h2>

<a href="/Admin/Index">Voltar</a>
<a href="/Login/Logout" style="float:right;">❌</a>

<hr />

<form method="post">

    <input name="Nome" placeholder="Nome" /><br /><br />

    <select name="Tipo">
        <option value="Fornecedor">Fornecedor</option>
        <option value="Comprador">Comprador</option>
    </select><br /><br />

    <input name="Email" placeholder="Login (email)" /><br /><br />
    <input name="Senha" placeholder="Senha" type="password" /><br /><br />

    <input name="Documento" placeholder="CNPJ/CPF" /><br /><br />
    <input name="Endereco" placeholder="Endereço" /><br /><br />
    <input name="Telefone" placeholder="Telefone" /><br /><br />
    <input name="Contato" placeholder="Contato" /><br /><br />

    <button type="submit">Salvar</button>

</form>
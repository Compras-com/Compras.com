@model List<Compras.com.Data.UsuarioFake>

<h2>⚙️ Painel do Administrador</h2>

<!-- 🔙 VOLTAR | 🔒 ALTERAR SENHA | ❌ -->
<a href="/Login/Logout">Voltar</a> |
<a href="/Conta/AlterarSenha">🔒 Alterar Senha</a>
<a href="/Login/Logout" style="float:right;">❌</a>

<hr />

<!-- 🔥 ENTRAR COMO -->
<h4>🔍 Acessar como:</h4>

<a href="/Admin/EntrarComoFornecedor">🏪 Entrar como Fornecedor</a> |
<a href="/Admin/EntrarComoComprador">🛒 Entrar como Comprador</a>

<hr />

<!-- ➕ CADASTRO -->
<a href="/Admin/Criar">➕ Cadastrar Fornecedor / Comprador</a>

<br /><br />

<table class="table table-bordered" style="width:100%;">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Tipo</th>
            <th>Email</th>
            <th>Status</th>
            <th>Ações</th>
        </tr>
    </thead>

    <tbody>
@if (Model != null && Model.Count > 0)
{
    foreach (var item in Model)
    {
        <tr>
            <td>@item.Nome</td>
            <td>@item.Tipo</td>
            <td>@item.Email</td>
            <td>
                @if (item.Ativo)
                {
                    <span style="color:green;">Ativo</span>
                }
                else
                {
                    <span style="color:red;">Bloqueado</span>
                }
            </td>
            <td>
                <a href="/Admin/Detalhes/@item.Id">👁️ Ver</a> |
                <a href="/Admin/Bloquear/@item.Id">🔒 Bloquear</a> |
                <a href="/Admin/Excluir/@item.Id">🗑️ Excluir</a>
            </td>
        </tr>
    }
}
else
{
    <tr>
        <td colspan="5">Nenhum usuário cadastrado</td>
    </tr>
}
    </tbody>
</table>
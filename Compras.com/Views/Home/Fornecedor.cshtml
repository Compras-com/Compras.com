<h2>🏪 Área do Fornecedor</h2>

<!-- 🔙 VOLTAR | 🔒 ALTERAR SENHA | ❌ FECHAR -->
<a href="/Login/Logout">Voltar</a> |
<a href="/Conta/AlterarSenha">Alterar Senha</a>
<a href="/Login/Logout" style="float:right;">❌</a>

<hr />

<h3>📦 Cadastrar Produto</h3>

<form method="post" action="/Fornecedor/Salvar">

    <input name="Nome" placeholder="Produto" /><br /><br />

    <input name="Preco" placeholder="Preço" /><br /><br />

    <input name="Imposto" placeholder="Imposto (ex: 3,5)" /><br /><br />

    <input name="Desconto" placeholder="Desconto (ex: 2,5)" /><br /><br />

    <button type="submit">Salvar</button>
</form>

<hr />

<h3>📋 Meus Produtos</h3>

<table border="1" width="100%">
    <tr>
        <th>Produto</th>
        <th>Preço</th>
        <th>Imposto</th>
        <th>Desconto</th>
    </tr>

@foreach (var p in Compras.com.Data.DadosFake.Produtos)
{
    <tr>
        <td>@p.Nome</td>
        <td>@p.Preco</td>
        <td>@p.Imposto</td>
        <td>@p.Desconto</td>
    </tr>
}
</table>
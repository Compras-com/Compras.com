<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Compras.com</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        body.dark {
            background-color: #121212;
            color: white;
        }

        body.dark table {
            color: white;
        }

        body.dark input,
        body.dark button {
            background-color: #333;
            color: white;
        }
    </style>
</head>
<body>

    <!-- 🔝 MENU -->
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-light border-bottom mb-3">
            <div class="container-fluid">

                <a class="navbar-brand" href="/Login/Index">Compras.com</a>

                <div class="collapse navbar-collapse">
                    <ul class="navbar-nav flex-grow-1">

                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/Login/Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/Home/Privacy">Privacy</a>
                        </li>

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- 📦 CONTEÚDO -->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- 🌙 BOTÃO MODO ESCURO -->
    <button onclick="toggleDark()" 
            style="position:fixed;bottom:15px;right:15px;padding:10px;border-radius:50%;">
        🌙
    </button>

    <!-- 🔧 SCRIPT -->
    <script>
        function toggleDark() {
            document.body.classList.toggle("dark");
        }
    </script>

</body>
</html>